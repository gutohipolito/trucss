{%- style -%}
  .trucss-contact {
    --bg-pink: #ECC3B2;
    --dark-grey: #282727;
  }
  
  .contact-header- faixa {
    background-color: var(--bg-pink);
    padding: 60px 0;
    margin-bottom: 60px;
    width: 100%;
  }
  
  .contact-header- faixa h1 {
    font-family: 'Big Caslon', serif;
    font-size: clamp(32px, 5vw, 56px);
    color: var(--dark-grey);
    margin: 0;
    font-weight: 400;
  }
  
  .contact-grid-boutique {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    padding-bottom: 80px;
  }
  
  @media screen and (max-width: 768px) {
    .contact-grid-boutique {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .contact-header- faixa {
      padding: 40px 0;
    }
  }
  
  .contact-info-content p {
    font-size: 16px;
    line-height: 1.6;
    color: #666;
    margin-bottom: 24px;
  }
  
  .contact-info-content .patent-note {
    font-size: 14px;
    color: #aaa;
    margin-bottom: 40px;
  }
  
  .contact-details-box h3 {
    font-size: 18px;
    font-weight: 700;
    text-transform: uppercase;
    border-bottom: 1px solid var(--dark-grey);
    display: inline-block;
    padding-bottom: 5px;
    margin-bottom: 24px;
  }
  
  .contact-item {
    margin-bottom: 24px;
  }
  
  .contact-item small {
    display: block;
    text-transform: uppercase;
    font-weight: 800;
    font-size: 11px;
    margin-bottom: 8px;
    letter-spacing: 0.1em;
    color: var(--dark-grey);
  }
  
  .contact-item a {
    text-decoration: none;
    font-size: 18px;
    color: #666;
    transition: color 0.3s;
  }
  
  .contact-item a.email-link {
    color: #C67C5A;
  }
{%- endstyle -%}

<div class="trucss-contact">
  <div class="contact-header- faixa">
    <div class="page-width">
      <h1>Entre em contato conosco!</h1>
    </div>
  </div>

  <div class="page-width">
    <div class="contact-grid-boutique">
      <!-- Left: Column Info -->
      <div class="contact-info-content">
        <p>Silvana Trucss, empreendedora responsável por desenvolver o suporte mais eficiente e prático do mercado trans.</p>
        <p class="patent-note">Todos nossos produtos são patenteados.</p>
        
        <div class="contact-details-box">
          <h3>São Paulo</h3>
          
          <div class="contact-item">
            <small>TELEFONE:</small>
            <a href="https://wa.me/5511999825169" target="_blank">+55 (11) 99982- 5169</a>
          </div>
          
          <div class="contact-item">
            <small>E-MAIL:</small>
            <a href="mailto:contato@trucss.com.br" class="email-link">contato@trucss.com.br</a>
          </div>
        </div>
      </div>

      <!-- Right: Column Form (Dynamic) -->
      <div class="contact-form-wrapper">
        {%- assign contact_form_id = 'ContactForm-' | append: section.id -%}
        {%- form 'contact', id: contact_form_id -%}
          {%- if form.posted_successfully? -%}
            <div class="form-status form-status-list form__message" tabindex="-1" autofocus>
              {% render 'icon-success' %} {{ 'templates.contact.form.post_success' | t }}
            </div>
          {%- elsif form.errors -%}
            <div class="form__message">
              <h2 class="form-status caption-large text-body" role="alert" tabindex="-1" autofocus>
                {% render 'icon-error' %} {{ 'templates.contact.form.error_heading' | t }}
              </h2>
            </div>
          {%- endif -%}

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
            <div class="field">
              <input class="field__input" autocomplete="name" type="text" id="ContactForm-name" name="contact[{{ 'templates.contact.form.name' | t }}]" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}" placeholder="Nome">
            </div>
            <div class="field">
              <input autocomplete="email" type="email" id="ContactForm-email" class="field__input" name="contact[email]" spellcheck="false" autocapitalize="off" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" aria-required="true" {% if form.errors contains 'email' %} aria-invalid="true" aria-describedby="ContactForm-email-error" {% endif %} placeholder="E-mail">
            </div>
          </div>

          <div class="field" style="margin-bottom: 20px;">
            <input type="tel" id="ContactForm-phone" class="field__input" autocomplete="tel" name="contact[{{ 'templates.contact.form.phone' | t }}]" pattern="[0-9\-]*" value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}" placeholder="Telefone">
          </div>

          <div class="field" style="margin-bottom: 30px;">
            <textarea rows="6" id="ContactForm-body" class="text-area field__input" name="contact[{{ 'templates.contact.form.comment' | t }}]" placeholder="Mensagem">{{- form.body -}}</textarea>
          </div>

          <div class="contact__button">
            <button type="submit" class="button" style="width: 100%; border-radius: 0; background: #282727; border: none; padding: 15px;">
              Enviar Mensagem
            </button>
          </div>
        {%- endform -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Trucss Contato Boutique",
  "settings": [],
  "presets": [
    {
      "name": "Trucss Contato Boutique"
    }
  ]
}
{% endschema %}
