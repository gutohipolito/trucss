<style>
  .footer-newsletter {
    padding: 100px 20px;
    background-color: #fbfbfb;
    text-align: center;
    position: relative;
    z-index: 1;
    border-top: 1px solid rgba(0,0,0,0.03);
    box-shadow: 0 -15px 40px rgba(0,0,0,0.02);
  }
  .footer-newsletter__container {
    max-width: 600px;
    margin: 0 auto;
  }
  .footer-newsletter__title {
    font-family: 'Inter', sans-serif;
    font-size: 32px;
    font-weight: 500;
    color: #282727;
    margin-bottom: 12px;
    letter-spacing: -0.02em;
  }
  .footer-newsletter__subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    color: #666;
    margin-bottom: 40px;
  }
  .footer-newsletter__form {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }
  .footer-newsletter__input-wrapper {
    width: 100%;
    position: relative;
  }
  .footer-newsletter__input {
    width: 100%;
    border: none;
    border-bottom: 1px solid #ddd;
    padding: 12px 0;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    background: transparent;
    outline: none;
    text-align: center;
    transition: border-color 0.3s ease;
  }
  .footer-newsletter__input::placeholder {
    color: #aaa;
    font-weight: 300;
  }
  .footer-newsletter__input:focus {
    border-bottom-color: #282727;
  }
  .footer-newsletter__button {
    background-color: #000;
    color: #fff;
    border: none;
    padding: 16px 60px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background-color 0.3s ease;
    margin-top: 10px;
  }
  .footer-newsletter__button:hover {
    background-color: #333;
  }
  .footer-newsletter--success {
    color: #282727;
    font-family: 'Inter', sans-serif;
    margin-top: 20px;
  }

  @media screen and (max-width: 768px) {
    .footer-newsletter {
      padding: 60px 15px;
    }
    .footer-newsletter__title {
      font-size: 26px;
    }
    .footer-newsletter__button {
      width: 100%;
    }
  }
</style>

<div class="footer-newsletter">
  <div class="footer-newsletter__container">
    <h3 class="footer-newsletter__title">{{ section.settings.title }}</h3>
    <p class="footer-newsletter__subtitle">{{ section.settings.subtitle }}</p>

    {%- form 'customer', class: 'footer-newsletter__form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      
      <div class="footer-newsletter__input-wrapper">
        <input
          id="NewsletterForm-{{ section.id }}"
          type="email"
          name="contact[email]"
          class="footer-newsletter__input"
          value="{{ form.email }}"
          aria-required="true"
          autocorrect="off"
          autocapitalize="off"
          autocomplete="email"
          {% if form.errors %}
            autofocus
            aria-invalid="true"
            aria-describedby="Newsletter-error--{{ section.id }}"
          {% elsif form.posted_successfully? %}
            aria-describedby="Newsletter-success--{{ section.id }}"
          {% endif %}
          placeholder="Digite seu e-mail..."
          required
        >
      </div>
      
      <button 
        type="submit" 
        class="footer-newsletter__button" 
        name="commit" 
        id="Subscribe-{{ section.id }}"
      >
        Cadastrar
      </button>

      {%- if form.errors -%}
        <small class="footer-newsletter--error" id="Newsletter-error--{{ section.id }}">
          {{- form.errors.translated_fields.email | capitalize }}
          {{ form.errors.messages.email -}}
        </small>
      {%- endif -%}

      {%- if form.posted_successfully? -%}
        <h4
          class="footer-newsletter--success"
          id="Newsletter-success--{{ section.id }}"
          tabindex="-1"
          autofocus
        >
          Obrigado por se inscrever!
        </h4>
      {%- endif -%}
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "Footer Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Cadastre-se na Newsletter!"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Seja a primeira a saber sobre nossas novidades e ofertas exclusivas."
    }
  ],
  "presets": [
    {
      "name": "Footer Newsletter"
    }
  ]
}
{% endschema %}
