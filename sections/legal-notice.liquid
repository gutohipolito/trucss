
{%- style -%}
  .legal-notice-section {
    --bg-pink: #ECC3B2;
    --dark-grey: #282727;
  }
  
  .legal-notice-section .page-width {
    max-width: var(--narrow-page-width);
    margin: 0 auto;
    padding: 0 5rem;
  }

  .legal-header-faixa {
    background-color: var(--bg-pink);
    padding: 60px 0;
    margin-bottom: 60px;
    width: 100%;
    text-align: left;
  }
  
  .legal-header-faixa h1 {
    font-family: 'Big Caslon', 'Garamond', serif;
    font-size: clamp(32px, 5vw, 56px);
    color: var(--dark-grey);
    margin: 0;
    font-weight: 400;
  }

  .legal-notice-content {
    display: flex;
    flex-direction: column;
    gap: 30px;
    padding-bottom: 80px;
  }

  .legal-notice-content h2 {
    font-size: 20px;
    margin-top: 10px;
    margin-bottom: 16px;
    color: var(--dark-grey);
    font-weight: 700;
    border-bottom: 1px solid var(--dark-grey);
    display: inline-block;
    padding-bottom: 5px;
  }

  .legal-notice-content p {
    font-size: 16px;
    line-height: 1.7;
    color: #666;
    margin-bottom: 15px;
  }

  @media screen and (max-width: 768px) {
    .legal-notice-section .page-width {
      padding: 0 20px;
    }
    .legal-header-faixa {
      padding: 40px 0;
      margin-bottom: 40px;
    }
    .legal-notice-content {
      padding-bottom: 60px;
    }
  }
{%- endstyle -%}

