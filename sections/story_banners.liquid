<style>
  .story-banners { padding: 80px 20px; background: #fff; }
  .story-banners__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; max-width: 1400px; margin: 0 auto; }
  .story-banner { position: relative; aspect-ratio: 1/1; overflow: hidden; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; text-decoration: none; color: #282727; }
  .story-banner img { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: 1; }
  .story-banner__overlay { position: absolute; inset: 0; background: rgba(245, 235, 225, 0.4); z-index: 2; }
  .story-banner__content { position: relative; z-index: 3; padding: 20px; }
  .story-banner__subtitle { font-family: Inter; font-size: 13px; text-transform: uppercase; letter-spacing: 2px; }
  .story-banner__title { font-family: Inter; font-size: 42px; margin: 10px 0; font-weight: 500; }
  .story-banner__button { background: #282727; color: #fff; padding: 12px 25px; font-size: 12px; text-transform: uppercase; border: none; margin-top: 20px; }
  @media (max-width: 768px) { .story-banners__grid { grid-template-columns: 1fr; } }
</style>

<div class="story-banners">
  <div class="story-banners__grid">
    {% for block in section.blocks %}
      <a href="{{ block.settings.link }}" class="story-banner">
        {%- assign img_id = 'img-' | append: forloop.index | append: '.jpg' -%}
        <img src="{{ img_id | asset_url }}" alt="Banner">
        <div class="story-banner__overlay"></div>
        <div class="story-banner__content">
          <span class="story-banner__subtitle">{{ block.settings.subtitle }}</span>
          <h3 class="story-banner__title">{{ block.settings.title }}</h3>
          <button class="story-banner__button">{{ block.settings.button_text }}</button>
        </div>
      </a>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Story Banners",
  "settings": [],
  "blocks": [
    {
      "type": "banner",
      "name": "Banner",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagem"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtítulo",
          "default": "Subtítulo"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Título"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Texto do Botão",
          "default": "Ver Mais"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Story Banners",
      "blocks": [
        {
          "type": "banner"
        },
        {
          "type": "banner"
        },
        {
          "type": "banner"
        }
      ]
    }
  ]
}
{% endschema %}
