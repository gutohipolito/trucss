{% block style %}
<style>
  .story-banners {
    padding: 60px 20px;
    background-color: #fff;
  }
  .story-banners__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    max-width: 1400px;
    margin: 0 auto;
  }
  .story-banner {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    text-decoration: none;
    color: #282727;
  }
  .story-banner__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .story-banner:hover .story-banner__image {
    transform: scale(1.05);
  }
  .story-banner__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(245, 235, 225, 0.4); /* Overlay clara/rosada conforme imagem */
    z-index: 2;
  }
  .story-banner__content {
    position: relative;
    z-index: 3;
    padding: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }
  .story-banner__subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 500;
    opacity: 0.8;
  }
  .story-banner__title {
    font-family: 'Inter', sans-serif;
    font-size: 42px;
    font-weight: 500;
    margin: 0;
    line-height: 1.1;
  }
  .story-banner__button {
    margin-top: 24px;
    background-color: #282727;
    color: #fff;
    padding: 14px 28px;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: none;
    transition: background-color 0.3s ease;
  }
  .story-banner:hover .story-banner__button {
    background-color: #000;
  }

  @media screen and (max-width: 768px) {
    .story-banners {
      padding: 40px 15px;
    }
    .story-banners__grid {
      grid-template-columns: 1fr;
    }
    .story-banner__title {
      font-size: 32px;
    }
  }
</style>
{% endblock %}

<div class="story-banners">
  <div class="story-banners__grid">
    {% for block in section.blocks %}
      <a href="{{ block.settings.link }}" class="story-banner" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          <img 
            src="{{ block.settings.image | image_url: width: 1000 }}" 
            class="story-banner__image" 
            alt="{{ block.settings.title }}"
            loading="lazy"
          >
        {% else %}
           {% assign placeholder_image = 'img-' | append: forloop.index | append: '.jpg' %}
           <img src="{{ placeholder_image | asset_url }}" class="story-banner__image" alt="Banner Image">
        {% endif %}
        <div class="story-banner__overlay"></div>
        <div class="story-banner__content">
          <span class="story-banner__subtitle">{{ block.settings.subtitle }}</span>
          <h3 class="story-banner__title">{{ block.settings.title }}</h3>
          <button class="story-banner__button">{{ block.settings.button_text }}</button>
        </div>
      </a>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Story Banners",
  "settings": [],
  "blocks": [
    {
      "type": "banner",
      "name": "Banner",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagem"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtítulo",
          "default": "Subtítulo"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "Título"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Texto do Botão",
          "default": "Ver Mais"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Story Banners",
      "blocks": [
        {
          "type": "banner"
        },
        {
          "type": "banner"
        },
        {
          "type": "banner"
        }
      ]
    }
  ]
}
{% endschema %}
