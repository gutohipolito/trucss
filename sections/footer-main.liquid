<style>
  .footer-main {
    background-color: #282727;
    color: #fff;
    padding: 100px 20px 40px;
    font-family: 'Inter', sans-serif;
  }
  .footer-main__container {
    max-width: 1400px;
    margin: 0 auto;
  }
  .footer-main__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.2fr;
    gap: 60px;
    margin-bottom: 80px;
  }
  .footer-main__col-title {
    font-size: 18px;
    font-weight: 500;
    margin-bottom: 30px;
    color: #fff;
  }
  
  /* Branding Col */
  .footer-main__logo {
    margin-bottom: 25px;
    display: block;
  }
  .footer-main__logo img {
    height: 35px;
    filter: brightness(0) invert(1);
  }
  .footer-main__description {
    font-size: 15px;
    line-height: 1.6;
    color: rgba(255,255,255,0.7);
    margin-bottom: 15px;
  }
  .footer-main__patent {
    font-style: italic;
    font-size: 14px;
    color: rgba(255,255,255,0.5);
    margin-bottom: 30px;
  }
  .footer-main__socials {
    display: flex;
    gap: 20px;
  }
  .footer-main__social-link {
    color: #fff;
    opacity: 0.8;
    transition: opacity 0.3s;
  }
  .footer-main__social-link:hover {
    opacity: 1;
  }

  /* Links Col */
  .footer-main__menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .footer-main__menu-item {
    margin-bottom: 12px;
  }
  .footer-main__menu-link {
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    font-size: 15px;
    transition: color 0.3s, transform 0.3s;
    display: inline-block;
  }
  .footer-main__menu-link:hover {
    color: #fff;
    transform: translateX(5px);
  }

  /* Security Col */
  .footer-main__security-grid {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }
  .footer-main__security-item {
    display: flex;
    align-items: center;
    gap: 12px;
    color: rgba(255,255,255,0.6);
    font-size: 13px;
  }
  .footer-main__security-icon {
    width: 32px;
    height: 32px;
    fill: #fff;
    opacity: 0.8;
  }

  /* Payment Col */
  .footer-main__payment-pix {
    margin-bottom: 25px;
  }
  .footer-main__payment-pix svg {
    height: 24px;
    fill: #fff;
    opacity: 0.8;
  }
  .footer-main__payment-icons {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    max-width: 200px;
  }
  .footer-main__payment-icon {
    background: #fff;
    border-radius: 4px;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 28px;
  }
  .footer-main__payment-icon img {
    max-width: 100%;
    max-height: 100%;
    filter: none !important;
  }

  /* Bottom Bar */
  .footer-main__bottom {
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: 30px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
    color: rgba(255,255,255,0.4);
  }
  .footer-main__bottom-links {
    display: flex;
    gap: 30px;
  }
  .footer-main__bottom-link {
    color: rgba(255,255,255,0.4);
    text-decoration: none;
    transition: color 0.3s;
  }
  .footer-main__bottom-link:hover {
    color: #fff;
  }

  @media screen and (max-width: 990px) {
    .footer-main__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media screen and (max-width: 768px) {
    .footer-main {
      padding: 60px 20px 30px;
    }
    .footer-main__grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .footer-main__bottom {
      flex-direction: column;
      gap: 20px;
      text-align: center;
    }
    .footer-main__bottom-links {
      flex-wrap: wrap;
      justify-content: center;
      gap: 15px;
    }
  }
</style>

