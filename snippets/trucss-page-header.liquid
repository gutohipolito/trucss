{%- style -%}
  .trucss-boutique-header {
    --bg-pink: #ECC3B2;
    --dark-grey: #282727;
    background-color: var(--bg-pink);
    padding: 60px 0;
    margin-bottom: 60px;
    width: 100vw;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    text-align: left;
    margin-top: 0;
  }
  
  .trucss-boutique-header .header-content {
    max-width: var(--narrow-page-width);
    margin: 0 auto;
    padding: 0 5rem;
  }

  .trucss-boutique-header h1 {
    font-family: 'Big Caslon', 'Garamond', serif;
    font-size: clamp(32px, 5vw, 56px);
    color: var(--dark-grey);
    margin: 0;
    font-weight: 400;
  }

  @media screen and (max-width: 768px) {
    .trucss-boutique-header {
      padding: 40px 0;
    }
    .trucss-boutique-header .header-content {
      padding: 0 20px;
    }
  }
{%- endstyle -%}

{% liquid
  assign header_title = title
  if title == blank
    if search.performed
      assign header_title = 'content.search_results' | t
    elsif collection.title != blank
      assign header_title = collection.title
    elsif closest.collection.title != blank
      assign header_title = closest.collection.title
    elsif page.title != blank
      assign header_title = page.title
    endif
  endif
%}

<div class="trucss-boutique-header">
  <div class="header-content">
    <h1>{{ header_title }}</h1>
  </div>
</div>
