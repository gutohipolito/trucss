<shipping-calculator class="shipping-calculator" style="{% if block.settings.frete_dinamico_borda == false %}border:none;background:transparent;padding:0;{% endif %}">
  <div class="shipping-calculator__title">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
    {{ block.settings.frete_dinamico_titulo | default: 'Calcular Frete e Prazo' }}
  </div>
  <div class="shipping-calculator__input-group">
    <input type="text" class="shipping-calculator__input" placeholder="00000-000" maxlength="9">
    <button type="button" class="shipping-calculator__button" style="background-color: {{ block.settings.frete_dinamico_btn | default: '#000000' }};">Calcular</button>
  </div>
  <div class="shipping-calculator__production-notice" style="margin-top: 15px; font-size: 0.85rem; color: #c3002f; line-height: 1.4; display: flex; gap: 8px; align-items: flex-start; background: rgba(195, 0, 47, 0.05); padding: 12px; border-radius: 8px; border: 1px solid rgba(195, 0, 47, 0.1);">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0; margin-top: 2px;"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
    <span><strong>Importante:</strong> Nossas peças são artesanais. O prazo total é o tempo de trânsito + <strong>05 a 30 dias úteis</strong> de produção.</span>
  </div>
  <div class="shipping-calculator__results">
    <!-- Results will be injected by JS -->
  </div>
</shipping-calculator>

<style>
.shipping-calculator {
  display: block;
  width: 100%;
  margin-top: 0 !important;
  margin-bottom: 0 !important;
  padding: 4px 15px 12px 15px;
  background: #fdfaf9;
  border-radius: 12px;
  border: 1px solid rgba(0,0,0,0.05);
  box-sizing: border-box;
}

.shipping-calculator__title {
  font-size: 1.1rem;
  font-weight: 600;
  margin-bottom: 15px;
  display: flex;
  align-items: center;
  gap: 10px;
  color: #222;
}

.shipping-calculator__input-group {
  display: flex;
  gap: 10px;
  width: 100%;
}

.shipping-calculator__input {
  flex: 1;
  min-width: 0;
  padding: 12px 15px;
  border: 1px solid #ddd;
  border-radius: 8px;
  font-size: 1rem;
  background: #fff;
}

.shipping-calculator__button {
  padding: 12px 25px;
  color: #fff;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  font-weight: 600;
  white-space: nowrap;
  transition: opacity 0.2s;
}

.shipping-calculator__results {
  margin-top: 20px;
  display: none;
  border-top: 1px solid #eee;
  padding-top: 15px;
}

.shipping-calculator__result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px dashed #eee;
  font-size: 0.95rem;
}

.shipping-calculator__result-item:last-child {
  border-bottom: none;
}

@media (max-width: 600px) {
  .shipping-calculator {
    padding: 15px;
  }
  .shipping-calculator__input-group {
    flex-direction: column;
  }
  .shipping-calculator__button {
    width: 100%;
  }
}
</style>

{{ 'shipping-calculator.js' | asset_url | script_tag }}
