<script>
function copyCoupon() {
  navigator.clipboard.writeText('PRIMEIRACOMPRA');
  const btn = document.getElementById('cupom-copy-btn');
  const content = document.getElementById('cupom-copy-content');
  btn.classList.add('copiado');
  content.innerHTML = `
    <svg width="18" height="18" fill="none" viewBox="0 0 24 24">
      <path fill="#fff" d="M9.5 16.2l-3.7-3.7 1.4-1.4 2.3 2.3 5.3-5.3 1.4 1.4z"/>
    </svg>
    <span style="font-weight:700; margin-left: 4px;">Copiado</span>
  `;
  setTimeout(() => {
    btn.classList.remove('copiado');
    content.innerHTML = `
      <svg class="cupom-copy-icon" width="16" height="16" fill="none" viewBox="0 0 24 24"><path fill="currentColor" d="M16 1H4a2 2 0 0 0-2 2v14h2V3h12V1zm3 4H8a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h11a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2zm0 18H8V7h11v16z"/></svg>
      <span class="cupom-copy-text" style="margin-left: 4px;">Copiar</span>
    `;
  }, 2000);
}
</script>

