    </svg>
    <span style="font-weight:600;">Copiado</span>
  `;
  setTimeout(() => {
    btn.classList.remove('copiado');
    content.innerHTML = `
      <svg class="cupom-copy-icon" width="17" height="17" fill="none" viewBox="0 0 24 24"><path fill="#22a7ff" d="M16 1H4a2 2 0 0 0-2 2v14h2V3h12V1zm3 4H8a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h11a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2zm0 18H8V7h11v16z"/></svg>
