<script>
function copyCoupon() {
  navigator.clipboard.writeText('PRIMEIRACOMPRA');
  const btn = document.getElementById('cupom-copy-btn');
  const content = document.getElementById('cupom-copy-content');
  btn.classList.add('copiado');
  content.innerHTML = `
    <svg width="20" height="20" style="margin-right:5px;margin-bottom:-2px" fill="none" viewBox="0 0 24 24">
      <path fill="#fff" d="M0 0h24v24H0z" fill-opacity="0"/>
