{%- assign texto_aviso = block.settings.texto | default: 'IMPORTANTE : Prazo de 5 à 30 dias úteis para fabricação da peça + prazo de envio.' -%}
{%- assign texto_aviso_formatado = texto_aviso | newline_to_br | replace: 'IMPORTANTE', '<span class="aviso-badge">IMPORTANTE</span>' -%}

<div class="aviso-fabricacao-container">
  <div class="aviso-row">
    <div class="aviso-icon">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="16" x2="12" y2="12"></line>
        <line x1="12" y1="8" x2="12.01" y2="8"></line>
      </svg>
    </div>
    <div class="aviso-content">
      <p class="aviso-text">{{ texto_aviso_formatado }}</p>
    </div>
  </div>
</div>

<style>
.aviso-fabricacao-container {
  width: 100%;
  margin: 16px 0;
}

.aviso-row {
  display: flex;
  align-items: flex-start;
  background: #fff8f8;
  border: 1px solid #fecaca;
  padding: 14px 18px;
  border-radius: 14px;
  gap: 14px;
  box-shadow: 0 2px 8px rgba(195, 0, 47, 0.05);
}

.aviso-icon {
  color: #c3002f;
  flex-shrink: 0;
  margin-top: 4px;
}

.aviso-content {
  flex-grow: 1;
}

.aviso-text {
  margin: 0;
  font-size: 13px;
  line-height: 1.6;
  color: #2c2c2c;
  font-weight: 500;
}

.aviso-badge {
  background: #c3002f;
  color: #fff;
  padding: 2px 8px;
  border-radius: 6px;
  font-size: 11px;
  font-weight: 800;
  text-transform: uppercase;
  margin-right: 4px;
  display: inline-block;
  vertical-align: middle;
  letter-spacing: 0.5px;
}

.aviso-text strong, 
.aviso-text b {
  color: #c3002f;
  font-weight: 700;
}
</style>
