{%- style -%}
  .trucss-how-it-works {
    --bg-pink: #ECC3B2;
    --dark-grey: #282727;
  }
  
  .page-width-boutique {
    max-width: var(--narrow-page-width);
    margin: 0 auto;
    padding: 0 5rem;
  }


  .video-container {
    position: relative;
    padding-bottom: 56.25%; /* 16:9 ratio */
    height: 0;
    overflow: hidden;
    max-width: 100%;
    background: #000;
    margin-bottom: 40px;
  }

  .video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .cta-container {
    text-align: center;
    padding-bottom: 80px;
  }

  .btn-premium {
    display: inline-block;
    background-color: var(--dark-grey);
    color: #fff !important;
    padding: 18px 60px;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 16px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: all 0.3s ease;
    border: none;
    border-radius: 0;
  }

  @media screen and (max-width: 768px) {
    .page-width-boutique {
      padding: 0 20px;
    }
  }
{%- endstyle -%}


  <div class="page-width-boutique">
    <div class="video-container">
      <iframe 
        src="https://www.youtube.com/embed/OypHcKvndLY" 
        title="Como Funciona Trucss" 
        frameborder="0" 
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
        allowfullscreen>
      </iframe>
    </div>

    <div class="cta-container">
      <a href="/collections/all" class="btn-premium">Ir às compras</a>
    </div>
  </div>
</div>
